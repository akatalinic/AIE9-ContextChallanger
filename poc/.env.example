# OpenAI credentials and model selection
OPENAI_API_KEY= # Required: API key used by all OpenAI requests.
SUPERVISOR_MODEL=gpt-5 # Model used by LLM supervisor planning/routing.
OPENAI_QGEN_MODEL=gpt-4.1-mini # Model used by question generation.
OPENAI_QA_MODEL=gpt-5.2 # Model used by QA answering/classification.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small # Embedding model used for retrieval indexing/search.
OPENAI_RAGAS_MODEL=gpt-4.1-mini # Model used by RAGAS evaluation LLM wrapper.
OPENAI_RAGAS_EMBEDDING_MODEL=text-embedding-3-small # Embedding model used by RAGAS evaluator.

# QGen behavior
QGEN_QUESTIONS_PER_CHUNK=10 # Max number of questions requested per chunk.
QGEN_TEMPERATURE=0.0 # Sampling temperature for QGen model calls.
QGEN_SEED=13 # Seed for deterministic/stable QGen outputs.
QGEN_STRICT_ANSWERABLE_ONLY=1 # Keep fewer questions instead of adding weak fallbacks.
QGEN_GROUNDING_MIN_OVERLAP_TOKENS=2 # Minimum token overlap required with source context.
QGEN_MAX_CONTEXT_TOKENS=6000 # Max context tokens sent to QGen per chunk.
QGEN_MAX_QUESTIONS_PER_DOC=10 # Hard upper bound for generated questions in single call.
QGEN_MIN_QUESTIONS_PER_DOC=3 # Minimum questions targeted in single call.
QGEN_EXCLUSION_MIN_TOKENS=4 # Min shared content tokens before similarity exclusion can apply.
QGEN_EXCLUSION_SIMILARITY_THRESHOLD=0.60 # Jaccard threshold to exclude near-duplicate excluded intents.
SUPERVISOR_LLM_ENABLED=1 # Enables LLM-driven supervisor planning (1=true, 0=false deterministic only).
SUPERVISOR_TIMEOUT=30 # Timeout in seconds for supervisor planning LLM call.

# QA behavior
QA_TOP_K=12 # Number of retrieved contexts considered per question.
QA_MAX_CONTEXT_TOKENS=12000 # Max context tokens sent to QA model.
QA_TEMPERATURE=0.0 # Sampling temperature for QA model calls.
QA_TIMEOUT=60 # Per-request timeout (seconds) for QA model calls.
QA_GLOSSARY_MAX_TERMS=8 # Max glossary terms injected into QA prompt.
QA_GLOSSARY_SNIPPETS_PER_TERM=2 # Max snippets collected per glossary term.
QA_EXTERNAL_MIN_INTERNAL_HITS=2 # Trigger external fallback only when internal hits are below this count.
QA_EXTERNAL_TOP_K=3 # Max external search snippets merged into QA context.
QA_CONTEXT_PRUNE_MIN_CHARS=80 # Minimum chars for containment-pruning in QA context dedupe.
QA_TOP1_SCORE_THRESHOLD=0.80 # If top retrieval score >= threshold, use top-1 context only.

# RAGAS evaluation
RAGAS_MAX_WORKERS=4 # Max concurrent workers during RAGAS evaluation.
RAGAS_TIMEOUT_SECONDS=180 # Timeout per RAGAS evaluator call.
RAGAS_REFERENCE_MIN_CONFIDENCE=0.80 # Minimum confidence for canonical/gold reference usage.

# Retrieval and chunking
READINESS_THRESHOLD=0.90 # Readiness score threshold for dashboard readiness signal.
EMBEDDING_DIMENSIONS=1536 # Vector dimension expected by Qdrant collection schema.
QDRANT_COLLECTION_BASELINE=cc_baseline # Baseline retrieval collection name.
QDRANT_COLLECTION_PARENT=cc_parent # Parent/child retrieval collection name.
QDRANT_URL=:memory: # Qdrant location (:memory: for in-process local mode).
CHUNK_SIZE=1000 # Baseline chunk size for document chunking.
CHUNK_OVERLAP=200 # Baseline chunk overlap for document chunking.
PARENT_CHUNK_SIZE=2000 # Parent chunk size for parent retriever indexing.
PARENT_CHUNK_OVERLAP=200 # Parent chunk overlap for parent retriever indexing.
CHILD_CHUNK_SIZE=400 # Child chunk size for parent retriever indexing.
CHILD_CHUNK_OVERLAP=50 # Child chunk overlap for parent retriever indexing.

# Optional external web fallback
TAVILY_API_KEY= # Optional Tavily API key for gated external search fallback.
TAVILY_TIMEOUT_SECONDS=20 # Tavily HTTP timeout in seconds.
TAVILY_SEARCH_DEPTH=basic # Tavily search depth (basic/advanced).

# Optional LangSmith tracing
LANGCHAIN_TRACING_V2=true # Enables LangSmith tracing when API key is present.
LANGCHAIN_API_KEY= # LangSmith API key; without it tracing is auto-disabled in RAGAS path.
LANGCHAIN_PROJECT=poc_cc_aie # LangSmith project name for trace grouping.
